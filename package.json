{
  "name": "memetomoney-ui-service",
  "version": "1.0.0",
  "private": true,
  "description": "Frontend UI service for Meme-to-Money platform",
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:prod": "NEXT_PUBLIC_API_ENV=production next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "cap:build:android": "npx cap sync android && cd android && ./gradlew assembleDebug",
    "cap:build:release": "npx cap sync android && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/browser": "^6.0.6",
    "@capacitor/camera": "^6.1.3",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/push-notifications": "^6.0.5",
    "@capacitor/share": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.11.3",
    "@emotion/styled": "^11.11.0",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^3.3.4",
    "@mui/icons-material": "^5.15.10",
    "@mui/material": "^5.15.10",
    "@mui/material-nextjs": "^7.3.7",
    "@mui/system": "^5.15.9",
    "axios": "^1.6.7",
    "emoji-picker-react": "^4.18.0",
    "firebase": "^12.3.0",
    "html-to-image": "^1.11.13",
    "js-cookie": "^3.0.5",
    "konva": "^10.2.0",
    "next": "14.1.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-dropzone": "^14.2.3",
    "react-hook-form": "^7.49.3",
    "react-konva": "^18.2.14",
    "react-query": "^3.39.3",
    "react-router-dom": "^6.21.3",
    "react-webcam": "^7.2.0",
    "recharts": "^2.10.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20.11.16",
    "@types/react": "18.2.52",
    "@types/react-dom": "18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "eslint": "8.56.0",
    "eslint-config-next": "14.1.0",
    "typescript": "5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
